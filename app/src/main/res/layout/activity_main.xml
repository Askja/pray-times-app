<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background_texture">

    <ScrollView
        android:id="@+id/rootScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_background_texture"
        android:fillViewport="true">

    <LinearLayout
        android:id="@+id/contentRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false"
            android:background="@drawable/home_header_background"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/dateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/color_on_primary_muted"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/calculationMethodText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/color_on_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/locationPickerFrame"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/location_picker_background"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:id="@+id/locationPickerIcon"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:padding="8dp"
                    android:src="@drawable/ic_location"
                    android:tint="@android:color/white" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/location_picker_title"
                        android:textColor="@color/color_on_primary_muted"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/locationSelectedText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/color_on_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/locationSelectedMetaText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/color_on_primary_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_chevron_down" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/openMonthTimesButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_action_background"
                    android:clickable="true"
                    android:contentDescription="@string/open_month_times"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_clock"
                        android:tint="@color/color_on_primary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/openHolidayCalendarButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_action_background"
                    android:clickable="true"
                    android:contentDescription="@string/open_holiday_calendar"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_calendar"
                        android:tint="@color/color_on_primary" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/openSettingsButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/home_action_background"
                    android:clickable="true"
                    android:contentDescription="@string/settings_title"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_settings"
                        android:tint="@color/color_on_primary" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/dayNavigationBar"
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:baselineAligned="false"
            android:orientation="horizontal">

            <Button
                android:id="@+id/previousDayButton"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/button_outline"
                android:drawableStart="@drawable/ic_back"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/previous_day"
                android:textAllCaps="false"
                android:textColor="@color/color_primary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/todayButton"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/button_primary"
                android:drawableStart="@drawable/ic_calendar"
                android:drawablePadding="6dp"
                android:drawableTint="@android:color/white"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/today"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp" />

            <Button
                android:id="@+id/nextDayButton"
                style="?android:attr/buttonBarButtonStyle"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/button_outline"
                android:drawableEnd="@drawable/ic_chevron_right"
                android:drawablePadding="6dp"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/next_day"
                android:textAllCaps="false"
                android:textColor="@color/color_primary"
                android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ramadanPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/holiday_accent_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/ramadanTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_moon"
                android:drawablePadding="8dp"
                android:gravity="center_vertical"
                android:text="@string/ramadan_panel_title"
                android:textColor="@color/color_accent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ramadanSuhoorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/color_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ramadanIftarText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/color_text"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ramadanTarawihText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/color_text"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/summaryPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/qiblaText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:drawableStart="@drawable/ic_qibla"
                android:drawablePadding="8dp"
                android:gravity="center_vertical"
                android:textColor="@color/color_muted"
                android:textSize="14sp" />

            <ru.admiral.praytimes.ui.QiblaCompassView
                android:id="@+id/qiblaCompass"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/mosquePanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_mosque"
                    android:drawablePadding="8dp"
                    android:gravity="center_vertical"
                    android:text="@string/mosques_title"
                    android:textColor="@color/color_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/refreshMosquesButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/button_outline"
                    android:minWidth="0dp"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="@string/mosques_refresh"
                    android:textAllCaps="false"
                    android:textColor="@color/color_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/mosques_subtitle"
                android:textColor="@color/color_muted"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/mosqueStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/color_muted"
                android:textSize="13sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/mosqueList"
                android:layout_width="match_parent"
                android:layout_height="320dp"
                android:layout_marginTop="10dp"
                android:clipToPadding="false"
                android:overScrollMode="ifContentScrolls"
                android:scrollbars="vertical" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/prayerPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_clock"
                android:drawablePadding="8dp"
                android:gravity="center_vertical"
                android:text="@string/home_block_prayer"
                android:textColor="@color/color_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/prayerProgressContainer"
                android:layout_width="match_parent"
                android:layout_height="178dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp">

                <ru.admiral.praytimes.ui.PrayerProgressView
                    android:id="@+id/prayerProgressView"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center" />

                <LinearLayout
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/currentPrayerNameText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:textColor="@color/color_text"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/currentPrayerTimeText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:textColor="@color/color_muted"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:id="@+id/fajrRow"
                style="@style/PrayerRowContainer"
                android:layout_width="match_parent"
                android:layout_height="58dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/fajrLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/prayer_fajr"
                        android:textColor="@color/color_text"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/fajrTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/color_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/fajrTime"
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/color_primary_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:id="@+id/fajrDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_divider" />

            <LinearLayout
                android:id="@+id/sunriseRow"
                style="@style/PrayerRowContainer"
                android:layout_width="match_parent"
                android:layout_height="58dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/sunriseLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/prayer_sunrise"
                        android:textColor="@color/color_text"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/sunriseTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/color_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/sunriseTime"
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/color_primary_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:id="@+id/sunriseDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_divider" />

            <LinearLayout
                android:id="@+id/dhuhrRow"
                style="@style/PrayerRowContainer"
                android:layout_width="match_parent"
                android:layout_height="58dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/dhuhrLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/prayer_dhuhr"
                        android:textColor="@color/color_text"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/dhuhrTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/color_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/dhuhrTime"
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/color_primary_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:id="@+id/dhuhrDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_divider" />

            <LinearLayout
                android:id="@+id/asrRow"
                style="@style/PrayerRowContainer"
                android:layout_width="match_parent"
                android:layout_height="58dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/asrLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/prayer_asr"
                        android:textColor="@color/color_text"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/asrTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/color_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/asrTime"
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/color_primary_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:id="@+id/asrDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_divider" />

            <LinearLayout
                android:id="@+id/maghribRow"
                style="@style/PrayerRowContainer"
                android:layout_width="match_parent"
                android:layout_height="58dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/maghribLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/prayer_maghrib"
                        android:textColor="@color/color_text"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/maghribTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/color_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/maghribTime"
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/color_primary_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:id="@+id/maghribDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_divider" />

            <LinearLayout
                android:id="@+id/ishaRow"
                style="@style/PrayerRowContainer"
                android:layout_width="match_parent"
                android:layout_height="58dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/ishaLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/prayer_isha"
                        android:textColor="@color/color_text"
                        android:textSize="17sp" />

                    <TextView
                        android:id="@+id/ishaTimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/color_muted"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/ishaTime"
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textColor="@color/color_primary_dark"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/sunnahPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/sunnahPanelHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:contentDescription="@string/sunnah_collapse"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:drawableStart="@drawable/ic_star"
                    android:drawablePadding="8dp"
                    android:gravity="center_vertical"
                    android:text="@string/sunnah_prayers_title"
                    android:textColor="@color/color_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/sunnahPanelChevron"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:rotation="90"
                    android:src="@drawable/ic_chevron_right" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sunnahPanelBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/sunnah_prayers_subtitle"
                    android:textColor="@color/color_muted"
                    android:textSize="13sp" />

                <LinearLayout
                    android:id="@+id/sunnahPrayerList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/holidayPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:drawableStart="@drawable/ic_calendar"
                android:drawablePadding="8dp"
                android:gravity="center_vertical"
                android:text="@string/holidays"
                android:textColor="@color/color_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/holidayPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/holiday_current_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/holidayPreviewIcon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_moon"
                    android:tint="@color/color_info" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/holidayPreviewTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_info"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/holidayPreviewDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/color_muted"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="8dp"
                        android:background="@color/color_info" />

                    <TextView
                        android:id="@+id/nextHolidayText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/color_info"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
