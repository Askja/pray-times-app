<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_background_texture"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/batteryOptimizationPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/holiday_rose_background"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/battery_optimization_title"
                android:textColor="@color/color_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/battery_optimization_message"
                android:textColor="@color/color_text"
                android:textSize="13sp" />

            <Button
                android:id="@+id/openBatterySettingsButton"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/button_primary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/battery_optimization_disable"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/backButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:clickable="true"
            android:contentDescription="@string/back"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/back"
                android:textColor="@color/color_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/settings_header_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_settings" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_title"
                    android:textColor="@color/color_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/versionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/color_muted"
                android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/openLocationSettingsButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/row_background"
            android:clickable="true"
            android:contentDescription="@string/location_manage"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_location" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/location_manage"
                android:textColor="@color/color_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/openMethodComparisonButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/row_background"
            android:clickable="true"
            android:contentDescription="@string/method_comparison_title"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_clock" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/method_comparison_title"
                android:textColor="@color/color_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/openAccuracyButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/row_background"
            android:clickable="true"
            android:contentDescription="@string/accuracy_title"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_qibla" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/accuracy_title"
                android:textColor="@color/color_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_chevron_right" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/panel_background"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_language"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/languageSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_color_mode"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/colorModeSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/settings_ui_scale"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/uiScaleSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <CheckBox
                android:id="@+id/ramadanModeCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/ramadan_mode"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/holidayBackgroundsCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/use_holiday_backgrounds"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/hijri_day_adjustment"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/hijriAdjustmentSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/calculation_method"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/calculationMethodSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/asr_calculation_method"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/asrMethodSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/asr_calculation_method_hint"
                android:textColor="@color/color_muted"
                android:textSize="13sp" />

            <CheckBox
                android:id="@+id/showJumuahPrayerCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/show_jumuah_prayer"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/autoSwitchLocationCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/auto_switch_location"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/suggestLocationSwitchCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/suggest_location_switch"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/home_block_order_title"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/home_block_order_subtitle"
                android:textColor="@color/color_muted"
                android:textSize="13sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/homeBlockOrderList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/prayer_adjustments_title"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/prayerAdjustmentsScopeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/color_muted"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/fajrAdjustmentEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="@string/prayer_fajr_short"
                    android:inputType="numberSigned"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/color_text"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/sunriseAdjustmentEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="@string/prayer_sunrise_short"
                    android:inputType="numberSigned"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/color_text"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/dhuhrAdjustmentEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="@string/prayer_dhuhr_short"
                    android:inputType="numberSigned"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/color_text"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/asrAdjustmentEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="@string/prayer_asr_short"
                    android:inputType="numberSigned"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/color_text"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/maghribAdjustmentEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="@string/prayer_maghrib_short"
                    android:inputType="numberSigned"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/color_text"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/ishaAdjustmentEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="@string/prayer_isha_short"
                    android:inputType="numberSigned"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/color_text"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/iqama_offsets_title"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/iqamaOffsetsScopeText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/color_muted"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/fajrIqamaEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="@string/prayer_fajr_short"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/color_text"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/dhuhrIqamaEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="@string/prayer_dhuhr_short"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/color_text"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/asrIqamaEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="@string/prayer_asr_short"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/color_text"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/maghribIqamaEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="@string/prayer_maghrib_short"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/color_text"
                    android:textSize="13sp" />

                <EditText
                    android:id="@+id/ishaIqamaEditText"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:hint="@string/prayer_isha_short"
                    android:inputType="number"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:textColor="@color/color_text"
                    android:textSize="13sp" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/settings_notifications"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <CheckBox
                android:id="@+id/notifyAtPrayerStartCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/notify_at_prayer_start"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/notifyBeforePrayerStartCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/notify_before_prayer_start"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/notifyBeforePrayerEndCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/notify_before_prayer_end"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/playAdhanAtPrayerStartCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/play_adhan_at_prayer_start"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/adhan_sound"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/adhanSoundSpinner"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <CheckBox
                android:id="@+id/notifySunnahPrayersCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/notify_sunnah_prayers"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/notifyRamadanImsakCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/notify_ramadan_imsak"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <CheckBox
                android:id="@+id/vibratePrayerNotificationsCheckBox"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:buttonTint="@color/color_primary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/vibrate_prayer_notifications"
                android:textColor="@color/color_text"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/notification_profiles"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/notificationProfileList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/backup_title"
                android:textColor="@color/color_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/exportBackupButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_outline"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="@string/backup_export"
                    android:textAllCaps="false"
                    android:textColor="@color/color_primary"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/importBackupButton"
                    android:layout_width="0dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/button_outline"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="@string/backup_import"
                    android:textAllCaps="false"
                    android:textColor="@color/color_primary"
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/applySettingsButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/button_primary"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="@string/settings_apply"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
